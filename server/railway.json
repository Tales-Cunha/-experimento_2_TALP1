{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/server/Dockerfile",
    "watchPatterns": [
      "/server/**",
      "/shared/**"
    ],
    "buildCommand": null
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "cronSchedule": null
  }
}
